# FastAPI Configuration
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# YOLO Configuration
YOLO_CONF_THRESHOLD=0.20
YOLO_DEVICE=0  # 0 for GPU, 'cpu' for CPU

# Disease Detection Configuration
DISEASE_THRESHOLD=0.4

# API Configuration
MAX_FILE_SIZE=50  # MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,webp

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/api.log

# Enable/Disable Features
ENABLE_DISEASE_DETECTION=true
ENABLE_BATCH_PREDICTION=true
ENABLE_CORS=true

# CORS Settings
CORS_ORIGINS=*
